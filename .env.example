# API Key for authentication (required)
API_KEY=your-api-key

# Server port (default: 5505)
PORT=5505

# Whisper model: standard names (tiny, base, small, medium, large-v2, large-v3)
# or HuggingFace model IDs for fine-tuned models, e.g.:
#   bangla-speech-processing/BanglaASR (Bengali fine-tuned, WhisperX compatible)
#   anuragshas/whisper-large-v2-bn (Bengali large, WhisperX compatible)
WHISPER_MODEL=base

# Device: cuda or cpu (auto-detects CUDA if available)
DEVICE=cuda

# Compute type: float16 (GPU) or int8 (CPU/low memory)
COMPUTE_TYPE=float16

# HuggingFace token (required for speaker diarization)
# Get from https://huggingface.co/settings/tokens
# Accept terms at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=
# ── YouTube / yt-dlp ─────────────────────────────────────────────
# YouTube blocks datacenter/VPS IPs (Oracle, AWS, etc.).
# You MUST provide cookies from a logged-in browser for YouTube to work on a VPS.
#
# Option A: Export a cookies.txt file from your browser and upload to server
# YTDLP_COOKIES_FILE=/path/to/cookies.txt
#
# Option B: If a browser is installed on the server (rare for VPS)
# YTDLP_COOKIES_FROM_BROWSER=chromium
#
# JS Runtime (required for YouTube signature decryption):
# yt-dlp only enables Deno by default. If using Node.js, set explicitly:
# YTDLP_JS_RUNTIMES=auto
# YTDLP_JS_RUNTIMES=node:/usr/bin/node
#
# YTDLP_VERBOSE=1   # show yt-dlp debug output
